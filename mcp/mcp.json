{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "servers": {
      "legacy-erp": {
        "type": "local",
        "command": ["node", "mcp/servers/legacy-erp.mcp.js"],
        "environment": {
          "ERP_BASE_URL": "https://erp.internal.acme.local/api/v1",
          "ERP_API_KEY": "${env:ERP_API_KEY}"
        },
        "enabled": true
      },
      "google-calendar": {
        "type": "local",
        "command": ["npx", "-y", "@modelcontextprotocol/server-google-calendar"],
        "environment": {
          "GOOGLE_CLIENT_ID": "${env:GOOGLE_CLIENT_ID}",
          "GOOGLE_CLIENT_SECRET": "${env:GOOGLE_CLIENT_SECRET}",
          "GOOGLE_REFRESH_TOKEN": "${env:GOOGLE_REFRESH_TOKEN}"
        },
        "enabled": true
      },
      "crm": {
        "type": "local",
        "command": ["node", "mcp/servers/crm.mcp.js"],
        "environment": {
          "CRM_BASE_URL": "https://crm.internal.acme.local/api/v1",
          "CRM_API_KEY": "${env:CRM_API_KEY}"
        },
        "enabled": false
      }
    }
  }
}
