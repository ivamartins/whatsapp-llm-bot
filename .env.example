# ===== LLM Provider (agnostic, OpenAI-compatible chat completions) =====
# Choose a built-in preset OR set LLM_BASE_URL + LLM_MODEL directly.

# Preset: xai (Grok) | openai | openrouter | ollama | lmstudio | custom
LLM_PROVIDER=xai

# Required for hosted providers (xai, openai, openrouter). Leave empty for local (ollama, lmstudio).
LLM_API_KEY=

# Optional overrides (if blank, derived from LLM_PROVIDER preset).
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL=grok-3-mini

# Generation params
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TIMEOUT_MS=30000

# Conversation context (last N messages per chat) sent to the LLM
CONTEXT_WINDOW=5

# ===== WhatsApp session auth (generated on first run via QR) =====
# Baileys auth state folder (multi-device, persistent)
# AUTH_FOLDER=./auth

# For production use PM2 or Docker with persistent auth/.
# See README for setup.
