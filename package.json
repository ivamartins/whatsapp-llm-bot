{
  "name": "whatsapp-llm-bot",
  "version": "1.0.0",
  "description": "LLM-agnostic WhatsApp bot. Connects to any OpenAI-compatible chat completions API (xAI Grok, OpenAI, OpenRouter, Ollama, LM Studio, vLLM, etc.) to auto-reply messages. Functional example of production-ready AI agents for system integrations and automations.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "docker:build": "docker build -t whatsapp-llm-bot .",
    "docker:run": "docker run --env-file .env -p 3000:3000 whatsapp-llm-bot",
    "test": "mocha test/*.js --exit"
  },
  "keywords": [
    "whatsapp",
    "llm",
    "ai-agents",
    "openai-compatible",
    "xai",
    "grok",
    "openai",
    "ollama",
    "automation",
    "legacy-systems",
    "integration",
    "baileys"
  ],
  "author": "Ivã Martins / Code Solutions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivamartins/whatsapp-llm-bot.git"
  },
  "homepage": "https://ivamartins.github.io/code-solutions-site/",
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "mocha": "^10.4.0",
    "chai": "^4.3.10"
  }
}
